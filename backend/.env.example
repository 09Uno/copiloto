# Copie para .env e preencha. O .env real nunca é versionado.
# Supabase: Settings → Database → Connection string → URI (session pooler, porta 5432)
DATABASE_URL=postgresql://postgres.<ref>:<senha>@aws-1-<regiao>.pooler.supabase.com:5432/postgres

# FinControl — a carteira real. Este sistema SÓ LÊ de lá, nunca escreve.
# Uma fonte só: registrar a mesma operação em dois lugares faz os dois ficarem desatualizados.
FINCONTROL_URL=https://fincontrol.codetoyou.tech
FINCONTROL_USER=
FINCONTROL_PASS=
