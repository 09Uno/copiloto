# Copie para .env e preencha. O .env real nunca é versionado.
# Supabase: Settings → Database → Connection string → URI (session pooler, porta 5432)
DATABASE_URL=postgresql://postgres.<ref>:<senha>@aws-1-<regiao>.pooler.supabase.com:5432/postgres

# FinControl — a carteira real. Este sistema SÓ LÊ de lá, nunca escreve.
# Uma fonte só: registrar a mesma operação em dois lugares faz os dois ficarem desatualizados.
FINCONTROL_URL=https://fincontrol.codetoyou.tech
FINCONTROL_USER=
FINCONTROL_PASS=

# Auth próprio do SaaS (portável — não depende de Supabase).
# Gere: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Busca de contexto (OPCIONAL). Liga o "buscar o que mudou" nos pilares qualitativos:
# lê notícias reais e o GPT só FILTRA as que tocam o pilar — nunca dá veredito. Sem esta
# chave, o recurso fica desligado (o botão nem aparece); o resto do sistema roda igual.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Resumo diário no WhatsApp (OPCIONAL). O n8n chama GET /api/resumo com o header
# X-Resumo-Token = RESUMO_TOKEN, e monta a mensagem para o grupo. Token de serviço (não expira,
# ao contrário do JWT). Gere: python -c "import secrets; print(secrets.token_hex(24))"
RESUMO_TOKEN=
RESUMO_EMAIL=          # e-mail da conta a resumir (a sua)
