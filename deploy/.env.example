# Copiloto — .env de PRODUÇÃO (VPS). Copie para ~/docker/sistemas/copiloto/.env e preencha.
# NUNCA versione este arquivo com valores reais.

# --- Banco: o Postgres COMPARTILHADO da VPS (mesmo container que o n8n usa) ---
# Host = nome do container (`postgres`), alcançável pelo proxy-net. Crie o db/usuário antes
# (ver deploy/README.md). Troque <SENHA_COPILOTO> pela que você definir.
DATABASE_URL=postgresql://copiloto:<SENHA_COPILOTO>@postgres:5432/copiloto

# --- Auth do app (gere um NOVO, não reaproveite o de dev) ---
# python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# --- FinControl (a carteira; só leitura) ---
FINCONTROL_URL=https://fincontrol.codetoyou.tech
FINCONTROL_USER=
FINCONTROL_PASS=

# --- Busca de contexto (opcional) — a chave NOVA, depois de rotacionar a que vazou ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Resumo diário no WhatsApp ---
# python -c "import secrets; print(secrets.token_hex(24))"
RESUMO_TOKEN=
RESUMO_EMAIL=bruno.a.oliveira.1209@gmail.com

# --- CORS: só importa no PASSO 2 (painel web público). Libere o domínio do painel. ---
CORS_ORIGENS=https://copiloto.codetoyou.tech
